{
  "name": "quiz-engine-api",
  "version": "0.1.0",
  "private": true,
  "description": "Quiz Engine API built as a NestJS modular monolith.",
  "engines": {
    "node": "24.18.0",
    "npm": ">=11"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "db:reset:dev": "node scripts/safe-prisma-reset.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "phase0:inventory": "find . -path './.git' -prune -o -type f -print | sort",
    "start": "node dist/main.js",
    "start:dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "test": "jest --runInBand --testPathIgnorePatterns=/test/",
    "test:e2e": "jest --runInBand --setupFiles=./test/e2e-env.setup.ts --testRegex=test/.*\\.e2e-spec\\.ts$",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "6.19.3",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "helmet": "^8.3.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/testing": "^11.1.28",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.3",
    "@types/supertest": "^7.2.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.4.2",
    "prettier": "^3.9.5",
    "prisma": "6.19.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "preset": "ts-jest",
    "rootDir": ".",
    "testEnvironment": "node",
    "testRegex": ".*\\.spec\\.ts$"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
